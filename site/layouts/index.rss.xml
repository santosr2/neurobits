{{- $pages := where .Site.RegularPages "Section" "in" (.Site.Params.mainSections | default (slice "blog" "notes" "projects")) -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ .Site.Title }}</title>
    <link>{{ "/" | absURL }}</link>
    <description>{{ .Site.Params.description }}</description>
    <generator>Hugo</generator>
    <language>{{ .Site.LanguageCode }}</language>
    <atom:link href="{{ "index.xml" | absURL }}" rel="self" type="application/rss+xml" />
    {{- range first .Site.Config.Services.RSS.Limit $pages.ByDate.Reverse }}
      <item>
        <title>{{ .Title }}</title>
        <link>{{ .Permalink }}</link>
        <guid>{{ .Permalink }}</guid>
        {{- if .Date }}
          <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
        {{- end }}
        <description>{{ .Summary | plainify | html }}</description>
      </item>
    {{- end }}
  </channel>
</rss>
